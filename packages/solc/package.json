{
  "name": "@evm-effect/solc",
  "version": "0.0.0",
  "type": "module",
  "description": "Effect-TS bindings for compiling Solidity with solc (Node or Next.js worker)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/julia-script/evm-effect.git",
    "directory": "packages/solc"
  },
  "bugs": {
    "url": "https://github.com/julia-script/evm-effect/issues"
  },
  "homepage": "https://github.com/julia-script/evm-effect/tree/main/packages/solc",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./*": {
      "import": "./dist/*.js",
      "types": "./dist/*.d.ts"
    }
  },
  "scripts": {
    "build": "bun run build:worker && tsc --build tsconfig.build.json",
    "build:worker": "bun rspack build",
    "dev": "tsc --build tsconfig.build.json --watch",
    "test": "bun test",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@evm-effect/crypto": "workspace:*",
    "@evm-effect/ethereum-types": "workspace:*",
    "@noble/hashes": "catalog:",
    "effect": "catalog:",
    "node-polyfill-webpack-plugin": "^4.1.0",
    "solc": "^0.8.30",
    "solc-js": "^1.0.1",
    "ts-dedent": "^2.2.0"
  },
  "devDependencies": {
    "@effect/platform-bun": "^0.81.1",
    "@evm-effect/shared": "workspace:*",
    "@rspack/cli": "^1.7.9",
    "@rspack/core": "^1.7.9",
    "@types/bun": "catalog:",
    "fast-check": "catalog:",
    "tsdown": "^0.21.4"
  }
}
